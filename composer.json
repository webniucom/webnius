{
  "name": "webniucom/webnius",
  "type": "project",
  "keywords": [
    "high performance",
    "http service"
  ],
  "homepage": "https://www.webniu.com",
  "license": "MIT",
  "description": "High performance HTTP Service Framework.",
  "authors": [
    {
      "name": "webniu",
      "email": "admin@gicai.com",
      "homepage": "https://www.webniu.com",
      "role": "Developer"
    }
  ],
  "support": {
    "email": "admin@gicai.com",
    "issues": "https://github.com/webniucom/webnius/issues",
    "forum": "https://wenda.webniu.com/",
    "wiki": "https://webniu.com/doc/webnius",
    "source": "https://github.com/webniucom/webnius"
  },
  "require": {
    "php": ">=8.1",
    "workerman/webman-framework": "^2.1",
    "monolog/monolog": "^2.0",
    "webman/console": "^2.2",
    "webman/database": "^2.1",
    "webman/think-orm": "^2.1",
    "illuminate/pagination": "^12.54",
    "illuminate/events": "^12.54",
    "symfony/var-dumper": "^7.4",
    "webman/redis": "^2.1",
    "webman/validation": "^2.2"
  },
  "suggest": {
    "ext-event": "For better performance. "
  },
  "autoload": {
    "psr-4": {
      "": "./",
      "app\\": "./app",
      "App\\": "./app",
      "app\\View\\Components\\": "./app/view/components"
    }
  },
  "scripts": {
    "post-package-install": [
      "support\\Plugin::install"
    ],
    "post-package-update": [
      "support\\Plugin::install"
    ],
    "pre-package-uninstall": [
      "support\\Plugin::uninstall"
    ],
    "post-create-project-cmd": [
      "support\\Setup::run"
    ],
    "setup-webman": [
      "support\\Setup::run"
    ]
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
